# Local Environment Variables for DevCon App
# 
# Instructions:
# 1. Copy this file and rename it to `.env.local`
# 2. Ask your team admin for the correct AWS keys to fill in below.
# 3. DO NOT commit your `.env.local` file. It is ignored by git automatically.

# AWS Keys required for Polly TTS and Bedrock Explanations
AWS_DEFAULT_REGION="us-west-2"
AWS_ACCESS_KEY_ID="YOUR_ACCESS_KEY_ID_HERE"
AWS_SECRET_ACCESS_KEY="YOUR_SECRET_ACCESS_KEY_HERE"

# Your session token (Warning: this might expire frequently depending on your IAM setup)
AWS_SESSION_TOKEN="YOUR_SESSION_TOKEN_HERE"
